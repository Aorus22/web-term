# WebTerm Backend Configuration

# The port the backend server will listen on
WEBTERM_PORT=:8080

# Path to the SQLite database file
WEBTERM_DB_PATH=data/webterm.db

# 32-byte hex string for encrypting sensitive data (like SSH passwords)
# Generate one with: openssl rand -hex 32
WEBTERM_ENCRYPTION_KEY=

# Comma-separated list of glob patterns for allowed SSH hosts (SSRF protection)
# Leave empty to allow all (except metadata services)
WEBTERM_SSRF_ALLOWLIST=

# Comma-separated list of allowed CORS origins
WEBTERM_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
