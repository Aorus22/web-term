{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "webterm",
  "version": "0.1.0",
  "identifier": "com.webterm.desktop",
  "build": {
    "frontendDist": "../../fe/dist"
  },
  "app": {
    "defaultIcon": [
      "icons/icon.png",
      "icons/32x32.png"
    ],
    "windows": [
      {
        "title": "WebTerm",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "shadow": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/webterm-backend"
    ]
  },
  "plugins": {
    "shell": {
    }
  }
}
